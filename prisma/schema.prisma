generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserTier {
  FREE
  PRO
  ENTERPRISE
}

enum TradeType {
  BUY
  SELL
  EXCHANGE
}

enum Party {
  DEMOCRAT
  REPUBLICAN
  INDEPENDENT
  OTHER
}

enum Chamber {
  SENATE
  HOUSE
}

enum DataSource {
  QUIVERQUANT
  EDGAR
  CAPITOLTRADES
  POLYGON
  ALPHAVANTAGE
  FINNHUB
}

enum HoldingChange {
  NEW
  INCREASED
  DECREASED
  UNCHANGED
  EXITED
}

enum PositionAction {
  OPENED
  ADDED
  REDUCED
  CLOSED
}

enum AlertType {
  CONGRESS_TRADE
  INSTITUTION_FILING
  TRADER_POSITION
  STOCK_ACTIVITY
}

enum BlogCategory {
  ANALYSIS
  EDUCATION
  NEWS
  STRATEGY
  INSIDER_ACTIVITY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// Models
model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  tier                   UserTier  @default(FREE)

  accounts      Account[]
  sessions      Session[]
  alerts        Alert[]
  watchlistItems WatchlistItem[]
  blogComments  BlogComment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Politician {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  party         Party
  chamber       Chamber
  state         String
  district      String?
  imageUrl      String?
  totalTrades   Int       @default(0)
  avgReturnPct  Float?
  lastTradeDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trades CongressTrade[]

  @@map("politicians")
}

model CongressTrade {
  id           String     @id @default(cuid())
  externalId   String     @unique
  politicianId String
  ticker       String
  assetName    String?
  tradeType    TradeType
  amount       String
  amountLow    Float?
  amountHigh   Float?
  tradeDate    DateTime
  reportedDate DateTime
  description  String?
  priceAtTrade Float?
  priceNow     Float?
  returnPct    Float?
  source       DataSource @default(QUIVERQUANT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  politician Politician @relation(fields: [politicianId], references: [id])

  @@index([ticker])
  @@index([politicianId])
  @@index([tradeDate])
  @@map("congress_trades")
}

model Institution {
  id           String   @id @default(cuid())
  cik          String   @unique
  name         String
  slug         String   @unique
  aum          Float?
  filingCount  Int      @default(0)
  imageUrl     String?
  website      String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  filings Filing13F[]

  @@map("institutions")
}

model Filing13F {
  id              String   @id @default(cuid())
  institutionId   String
  accessionNumber String   @unique
  periodOfReport  DateTime
  filedAt         DateTime
  totalValue      Float?
  createdAt       DateTime @default(now())

  institution Institution  @relation(fields: [institutionId], references: [id])
  holdings    Holding13F[]

  @@map("filings_13f")
}

model Holding13F {
  id         String        @id @default(cuid())
  filingId   String
  ticker     String?
  cusip      String
  issuerName String
  shares     Float
  value      Float
  putCall    String?
  changeType HoldingChange?
  shareDiff  Float?

  filing Filing13F @relation(fields: [filingId], references: [id])

  @@map("holdings_13f")
}

model NotableTrader {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  imageUrl    String?
  knownFor    String?
  cik         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions TraderPosition[]

  @@map("notable_traders")
}

model TraderPosition {
  id           String         @id @default(cuid())
  traderId     String
  ticker       String
  issuerName   String
  action       PositionAction
  shares       Float?
  value        Float?
  reportedDate DateTime
  source       String
  createdAt    DateTime       @default(now())

  trader NotableTrader @relation(fields: [traderId], references: [id])

  @@map("trader_positions")
}

model Stock {
  id          String   @id @default(cuid())
  ticker      String   @unique
  name        String
  sector      String?
  industry    String?
  exchange    String?
  marketCap   Float?
  description String?
  watcherCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceCache StockPriceCache?

  @@map("stocks")
}

model StockPriceCache {
  id            String   @id @default(cuid())
  stockId       String   @unique
  currentPrice  Float
  open          Float?
  high          Float?
  low           Float?
  volume        BigInt?
  changePercent Float?
  priceHistory  Json
  lastFetchedAt DateTime

  stock Stock @relation(fields: [stockId], references: [id])

  @@map("stock_price_cache")
}

model WatchlistItem {
  id            String   @id @default(cuid())
  userId        String
  ticker        String?
  politicianId  String?
  institutionId String?
  traderId      String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@map("watchlist_items")
}

model Alert {
  id          String    @id @default(cuid())
  userId      String
  name        String
  alertType   AlertType
  conditions  Json
  channels    Json
  isActive    Boolean   @default(true)
  lastFiredAt DateTime?
  fireCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model BlogPost {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String
  content     String       @db.Text
  coverImage  String?
  author      String       @default("TradingWatcher Team")
  authorImage String?
  category    BlogCategory
  tags        String[]
  published   Boolean      @default(false)
  publishedAt DateTime?
  views       Int          @default(0)
  readMinutes Int          @default(5)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments BlogComment[]

  @@map("blog_posts")
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@map("blog_comments")
}

model SubscriptionPlan {
  id           String  @id @default(cuid())
  name         String
  stripePriceId String @unique
  price        Float
  interval     String
  features     Json
  isActive     Boolean @default(true)

  @@map("subscription_plans")
}

model SyncLog {
  id             String     @id @default(cuid())
  source         DataSource
  status         SyncStatus
  recordsNew     Int        @default(0)
  recordsUpdated Int        @default(0)
  errorMessage   String?
  startedAt      DateTime
  completedAt    DateTime?

  @@map("sync_logs")
}

// ─────────────────────────────────────────────
// Autonomous Trading System Models
// ─────────────────────────────────────────────

enum AgentType {
  MARKET_DATA
  SIGNAL
  ARBITRAGE
  EXECUTION
  LEARNING
  SELF_TEST
}

enum AgentStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
  STOPPED
}

enum TradingMode {
  PAPER
  LIVE
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum SignalType {
  MOMENTUM
  MEAN_REVERSION
  BREAKOUT
  ARBITRAGE
}

enum ArbitrageType {
  PAIRS
  ETF_SPREAD
  STATISTICAL
}

enum ArbitrageStatus {
  DETECTED
  EXECUTED
  EXPIRED
  CLOSED
}

model TradingAgent {
  id          String      @id @default(cuid())
  name        String
  type        AgentType
  status      AgentStatus @default(IDLE)
  mode        TradingMode @default(PAPER)
  config      Json
  symbols     String[]
  totalPnl    Float       @default(0)
  todayPnl    Float       @default(0)
  winRate     Float       @default(0)
  totalTrades Int         @default(0)
  lastRunAt   DateTime?
  errorCount  Int         @default(0)
  lastError   String?
  isActive    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trades    AgentTrade[]
  signals   TradingSignal[]
  backtests Backtest[]

  @@map("trading_agents")
}

model AgentTrade {
  id            String      @id @default(cuid())
  agentId       String
  symbol        String
  side          TradeSide
  qty           Float
  entryPrice    Float
  exitPrice     Float?
  stopLoss      Float?
  takeProfit    Float?
  status        TradeStatus @default(OPEN)
  mode          TradingMode
  pnl           Float?
  pnlPct        Float?
  alpacaOrderId String?
  timeframe     String
  strategy      String
  signalData    Json?
  entryAt       DateTime    @default(now())
  exitAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  agent TradingAgent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([symbol])
  @@index([status])
  @@map("agent_trades")
}

model PnLSnapshot {
  id            String      @id @default(cuid())
  mode          TradingMode
  totalPnl      Float
  dayPnl        Float
  openPositions Int
  equity        Float
  cash          Float
  timestamp     DateTime    @default(now())

  @@index([timestamp])
  @@map("pnl_snapshots")
}

model MarketCandle {
  id        String   @id @default(cuid())
  symbol    String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  vwap      Float?
  timestamp DateTime

  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timeframe])
  @@map("market_candles")
}

model TradingSignal {
  id         String      @id @default(cuid())
  agentId    String
  symbol     String
  type       SignalType
  direction  TradeSide
  strength   Float
  price      Float
  indicators Json
  timeframe  String
  actedOn    Boolean     @default(false)
  createdAt  DateTime    @default(now())

  agent TradingAgent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([createdAt])
  @@map("trading_signals")
}

model ArbitrageOpportunity {
  id           String           @id @default(cuid())
  type         ArbitrageType
  symbols      String[]
  spreadPct    Float
  zScore       Float
  estimatedPnl Float
  status       ArbitrageStatus  @default(DETECTED)
  actedOn      Boolean          @default(false)
  detectedAt   DateTime         @default(now())
  expiresAt    DateTime?
  metadata     Json?

  @@index([detectedAt])
  @@map("arbitrage_opportunities")
}

model Backtest {
  id          String      @id @default(cuid())
  agentId     String
  strategy    String
  config      Json
  startDate   DateTime
  endDate     DateTime
  totalReturn Float
  maxDrawdown Float
  sharpeRatio Float
  winRate     Float
  totalTrades Int
  results     Json
  createdAt   DateTime    @default(now())

  agent TradingAgent @relation(fields: [agentId], references: [id])

  @@map("backtests")
}

model TradingExchange {
  id          String      @id @default(cuid())
  name        String
  exchangeId  String
  apiKey      String
  secretKey   String
  sandbox     Boolean     @default(true)
  isPrimary   Boolean     @default(false)
  isActive    Boolean     @default(true)
  label       String?
  lastLatencyMs Float?
  lastLatencyAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("trading_exchanges")
}

model KimchiPremium {
  id          String   @id @default(cuid())
  premiumPct  Float
  btcKrw      Float
  btcUsdt     Float
  krwPerUsdt  Float
  signal      String   // STRONG_BULL | BULL | NEUTRAL | BEAR | STRONG_BEAR
  label       String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("kimchi_premium")
}

enum OpeningBoxStatus {
  WAITING_OPEN_CANDLE
  WAITING_BREAKOUT
  WAITING_RETRACEMENT
  IN_TRADE
  DONE
}

model OpeningBoxTrade {
  id                  String           @id @default(cuid())
  date                String           // YYYY-MM-DD UTC
  symbol              String
  mode                TradingMode      @default(PAPER)

  // Opening box (first 5-min candle)
  boxTop              Float?
  boxBottom           Float?
  boxRange            Float?
  openCandleTime      DateTime?
  openCandleOpen      Float?
  openCandleClose     Float?

  // Breakout
  breakoutDirection   String?          // LONG | SHORT
  breakoutCandleClose Float?
  breakoutTime        DateTime?
  retracementCandles  Int              @default(0)

  // Trade levels
  entryPrice          Float?
  stopLoss            Float?
  takeProfit          Float?

  // Execution
  status              OpeningBoxStatus @default(WAITING_OPEN_CANDLE)
  entryFillPrice      Float?
  exitPrice           Float?
  pnl                 Float?
  pnlPct              Float?
  exitReason          String?          // TP | SL | INVALIDATED | MANUAL
  entryAt             DateTime?
  exitAt              DateTime?
  orderId             String?

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([date, symbol, mode])
  @@index([date])
  @@map("opening_box_trades")
}

model ExchangeLatency {
  id          String   @id @default(cuid())
  exchangeId  String
  latencyMs   Float
  tier        String   // EXCELLENT | GOOD | FAIR | POOR | UNREACHABLE
  success     Boolean
  error       String?
  measuredAt  DateTime @default(now())

  @@index([exchangeId, measuredAt])
  @@map("exchange_latency")
}
